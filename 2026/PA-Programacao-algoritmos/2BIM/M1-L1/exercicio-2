* Descricao: Este codigo le um numero digitado e exibe todas as suas potencias
             parando no numero digitado
*/

#include <iostream>
using namespace std;

int main() {

    int numero;
    int potencia = 1;

    cout << "Digite um numero: ";
    cin >> numero;

    for (int i = 0; i <= numero; i++) {

        cout << "2^" << i << " = " << potencia << endl;

        potencia = potencia * 2;
    }

    return 0;
}
