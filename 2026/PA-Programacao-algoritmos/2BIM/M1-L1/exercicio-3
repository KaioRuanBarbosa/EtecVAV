#include <iostream>

using namespace std;

int main() {

    float numero, soma;

    soma = 0;

    cin >> numero;

    while(numero >= 0) {

        soma = soma + numero;

        cin >> numero;
    }

    cout << "Soma = " << soma;

    return 0;
}
